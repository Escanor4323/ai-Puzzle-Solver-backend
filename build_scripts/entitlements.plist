<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow network client connections (WebSocket, LLM APIs) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow network server (FastAPI/uvicorn listens on a port) -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Allow read/write to user-selected files (Milvus DB, data/) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow camera access (face recognition via DeepFace) -->
    <key>com.apple.security.device.camera</key>
    <true/>

    <!-- Disable library validation for ML model .so files -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow unsigned executable memory (PyTorch / ONNX Runtime) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow DYLD env vars (needed for some ML framework loading) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
