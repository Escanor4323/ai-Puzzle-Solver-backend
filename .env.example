# PuzzleMind Backend — Environment Variables
# Copy this file to .env and fill in the values.

# ── LLM Provider Selection ──────────────────────────────
# Controls which provider handles player-facing conversation.
# Accepted values: "claude" (default) | "vllm"
PUZZLEMIND_LLM_PROVIDER=claude

# ── Anthropic (Claude Sonnet + Haiku) ───────────────────
PUZZLEMIND_ANTHROPIC_API_KEY=sk-ant-...

# ── vLLM (self-hosted OpenAI-compatible) ────────────────
# Start vLLM: python -m vllm.entrypoints.openai.api_server \
#               --model meta-llama/Llama-3.1-8B-Instruct \
#               --port 8000
# Then set LLM_PROVIDER=vllm above.
PUZZLEMIND_VLLM_BASE_URL=http://localhost:8000/v1
PUZZLEMIND_VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
PUZZLEMIND_VLLM_API_KEY=EMPTY

# ── OpenAI (GPT-4o for puzzle generation) ───────────────
PUZZLEMIND_OPENAI_API_KEY=sk-...

# ── Ollama (Qwen 3 8B — local extraction) ──────────────
# Ollama must be running: brew install ollama && ollama serve
# Then: ollama pull qwen3:8b
PUZZLEMIND_OLLAMA_BASE_URL=http://localhost:11434/v1
PUZZLEMIND_OLLAMA_MODEL=qwen3:8b

# ── Debug Mode ──────────────────────────────────────────
PUZZLEMIND_DEBUG=true

# ── Hardware Lock ───────────────────────────────────────
PUZZLEMIND_HARDWARE_LOCK_ENABLED=false

# ── Server ──────────────────────────────────────────────
PUZZLEMIND_HOST=127.0.0.1
PUZZLEMIND_PORT=8008
