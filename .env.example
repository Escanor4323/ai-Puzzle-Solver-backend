# PuzzleMind Backend — Environment Variables
# Copy this file to .env and fill in the values.

# ── Anthropic (Claude Sonnet + Haiku) ───────────────────
PUZZLEMIND_ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (GPT-4o for puzzle generation) ───────────────
PUZZLEMIND_OPENAI_API_KEY=sk-...

# ── Ollama (Qwen 3 8B — local extraction) ──────────────
# Ollama must be running: brew install ollama && ollama serve
# Then: ollama pull qwen3:8b
PUZZLEMIND_OLLAMA_BASE_URL=http://localhost:11434/v1
PUZZLEMIND_OLLAMA_MODEL=qwen3:8b

# ── Debug Mode ──────────────────────────────────────────
PUZZLEMIND_DEBUG=true

# ── Hardware Lock ───────────────────────────────────────
PUZZLEMIND_HARDWARE_LOCK_ENABLED=false

# ── Server ──────────────────────────────────────────────
PUZZLEMIND_HOST=127.0.0.1
PUZZLEMIND_PORT=8008
